# Local self-host mode credentials. Do not commit real secrets.
# Official remote MCP mode hides these behind the platform token.
INTEGRATOR_ID=your_integrator_id
SECRET_ID=your_secret_id
SECRET_KEY=your_secret_key
DAAS_BASE_URL=https://console.handaas.com

# Optional high-screen / enterprise-search endpoint used by industry_chain_search_enterprises.
# In official platform deployment these can be set server-side, so users only need the MCP token.
HIGH_SCREEN_URL=https://example.com/enterprise-search-endpoint
HIGH_SCREEN_PRODUCT_ID=your_real_product_id_for_enterprise_search
HIGH_SCREEN_SECRET_ID=your_high_screen_secret_id
HIGH_SCREEN_SECRET_KEY=your_high_screen_secret_key

# Optional product-id overrides for evidence tools.
# INDUSTRY_CHAIN_EVIDENCE_PRODUCTS={"工商照面":"product_id","招聘明细":"product_id"}
PRODUCT_BUSINESS_PROFILE_ID=66dbccbec7a7e3460f5e613f
PRODUCT_ENTERPRISE_PROFILE_ID=6682b0b370f56cb7d77701e0
PRODUCT_ENTERPRISE_BUSINESS_ID=66e55613ae988a28c6db9259
PRODUCT_ENTERPRISE_TAG_ID=669e531ce1fd7bff82321d8d
PRODUCT_RECRUITING_DETAIL_ID=66d5b7e0537c3f61d646c346
PRODUCT_IP_STATS_ID=66d5b7df537c3f61d646c230
PRODUCT_BIDDING_INFO_ID=66bf124bf134a4c21b4fc2fa

# Server runtime.
HOST=127.0.0.1
PORT=8000
