# Local self-host mode credentials. Do not commit real secrets.
# Official remote MCP mode hides these behind the platform token.
INTEGRATOR_ID=your_integrator_id
SECRET_ID=your_secret_id
SECRET_KEY=your_secret_key
DAAS_BASE_URL=https://console.handaas.com
HANDAAS_TIMEOUT=30

# Optional product-id overrides are intentionally not required.
# This service wraps fixed existing HandaaS interfaces.
